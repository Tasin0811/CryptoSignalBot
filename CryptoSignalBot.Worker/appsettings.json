{
  "Bot": {
    "Symbols": [ "BTCUSDT", "ETHUSDT", "SOLUSDT", "BNBUSDT", "XRPUSDT" ],
    "Timeframes": [ "15m", "1h", "4h", "1d" ],
    "ReportTimeframes": [ "1h", "4h", "1d" ],
    "MinScoreToNotify": 7.5,
    "MaxReportSetups": 8,
    "DeduplicateReportMinutes": 60,
    "SignalDedupeMinutes": 60,
    "RetainCandlesDays": 365,
    "RetainSignalsDays": 365,
    "DryRunOnly": true
  },
  "ConnectionStrings": {
    "CryptoSignalBot": "Server=(localdb)\\MSSQLLocalDB;Database=CryptoSignalBot;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Binance": {
    "BaseUrl": "https://api.binance.com"
  },
  "CoinGecko": {
    "Enabled": true,
    "BaseUrl": "https://api.coingecko.com/api/v3",
    "ApiKey": ""
  },
  "Telegram": {
    "BotToken": "ENV:TELEGRAM_BOT_TOKEN",
    "ChatId": "ENV:TELEGRAM_CHAT_ID"
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "Username": "ENV:SMTP_USER",
    "Password": "ENV:SMTP_PASSWORD",
    "From": "ENV:SMTP_FROM",
    "To": "ENV:SMTP_TO"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  }
}
