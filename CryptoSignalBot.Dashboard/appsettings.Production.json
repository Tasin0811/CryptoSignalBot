{
  "Bot": {
    "Symbols": [ "BTCUSDT", "ETHUSDT", "SOLUSDT", "BNBUSDT", "XRPUSDT" ],
    "Timeframes": [ "1h", "4h", "1d" ],
    "ReportTimeframes": [ "1h", "4h", "1d" ],
    "MinScoreToNotify": 7.5,
    "MaxReportSetups": 8,
    "DeduplicateReportMinutes": 60,
    "SignalDedupeMinutes": 60,
    "RetainCandlesDays": 30,
    "RetainSignalsDays": 30,
    "DryRunOnly": true,
    "AccountBalance": 1000,
    "RiskPercent": 0.01
  },
  "Database": {
    "Provider": "Sqlite"
  },
  "ConnectionStrings": {
    "CryptoSignalBot": "Data Source=/tmp/cryptosignalbot.db"
  },
  "Binance": {
    "BaseUrl": "https://api.binance.com"
  },
  "CoinGecko": {
    "Enabled": true,
    "BaseUrl": "https://api.coingecko.com/api/v3",
    "ApiKey": ""
  },
  "Telegram": {
    "BotToken": "ENV:TELEGRAM_BOT_TOKEN",
    "ChatId": "ENV:TELEGRAM_CHAT_ID"
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "Username": "ENV:SMTP_USER",
    "Password": "ENV:SMTP_PASSWORD",
    "From": "ENV:SMTP_FROM",
    "To": "ENV:SMTP_TO"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "System.Net.Http": "Warning"
    }
  },
  "AllowedHosts": "*"
}
